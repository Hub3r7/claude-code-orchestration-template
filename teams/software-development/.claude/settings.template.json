{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-destructive-git.sh"
          }
        ]
      },
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/chain-circuit-breaker.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notes-persist.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "quality-gate|hunter|defender",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/gate-verdict-check.sh"
          }
        ]
      }
    ]
  }
}
