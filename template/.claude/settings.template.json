{
  "permissions": {
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(rm -rf *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/hooks/statusline-chain.sh"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-destructive-git.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/orchestrator-scope.sh"
          }
        ]
      },
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/chain-circuit-breaker.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/orchestrator-scope.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notes-persist.sh"
          },
          {
            "type": "prompt",
            "prompt": "Hook input: $ARGUMENTS\n\nA subagent just completed inside a tiered review chain. If tool_input.subagent_type is NOT one of quality-gate, hunter, defender, answer ok=true immediately. Otherwise check the subagent's output (tool_response) against the loop-back protocol: (1) a 'VERDICT: FAIL' must come with a numbered remediation list and must name the agent the work returns to; (2) a 'VERDICT: PASS' that includes a HANDOFF section must include acceptance criteria in it; (3) an output with neither a VERDICT nor a '## BLOCKED' section is a violation. Answer ok=false with one sentence naming exactly what is missing (so the orchestrator can send the agent back); otherwise ok=true.",
            "continueOnBlock": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-compact-orient.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "quality-gate|hunter|defender",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/gate-verdict-check.sh"
          }
        ]
      }
    ]
  }
}
